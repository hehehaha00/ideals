IDEA_AI_PROVIDER=openai
# Provider presets: openai, openrouter, deepseek, moonshot, siliconflow, relay, custom.
# For a preset, use its key directly (for example OPENAI_API_KEY or DEEPSEEK_API_KEY).
# IDEA_AI_API_KEY=replace-with-your-relay-key
# IDEA_AI_KEY_ENV=MY_CUSTOM_KEY
IDEA_API_PORT=8787
IDEA_AI_TIMEOUT_MS=60000
IDEA_AI_RETRY_COUNT=2
IDEA_AI_RETRY_BASE_DELAY_MS=350
IDEA_AI_MAX_CONCURRENCY=3
IDEA_AI_MAX_QUEUED_REQUESTS=12
IDEA_AI_REQUEST_DEADLINE_MS=90000
IDEA_AI_CACHE_TTL_MS=600000
IDEA_AI_CACHE_MAX_ENTRIES=200
IDEA_APP_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:5191,http://localhost:5191,http://127.0.0.1:5193,http://localhost:5193
# Optional, for relay sites blocked by Cloudflare/direct network.
IDEA_AI_PROXY_URL=http://127.0.0.1:7897
